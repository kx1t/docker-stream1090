#!/command/with-contenv bash
# shellcheck shell=bash disable=SC1091,SC2154
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026, Ramon F. Kolb (kx1t) and contributors

set -euo pipefail
source /scripts/common

default_rate=""
if [[ -f /run/stream1090/default_sample_rate ]]; then
    default_rate="$(< /run/stream1090/default_sample_rate)"
fi

sample_rate="${STREAM1090_SAMPLE_RATE:-$default_rate}"
if [[ -z "$sample_rate" ]]; then
    "${s6wrap[@]}" echo "STREAM1090_SAMPLE_RATE could not be determined"
    exit 1
fi

if [[ ! -f /run/stream1090/device.ini ]]; then
    "${s6wrap[@]}" echo "Missing /run/stream1090/device.ini"
    exit 1
fi

port="${STREAM1090_OUTPUT_PORT:-30001}"
host="${STREAM1090_OUTPUT_HOST:-0.0.0.0}"

stream_cmd=(
    /usr/local/bin/stream1090
    -s "$sample_rate"
    -d /run/stream1090/device.ini
)

if [[ -n "${STREAM1090_UPSAMPLE_RATE:-}" ]]; then
    stream_cmd+=( -u "${STREAM1090_UPSAMPLE_RATE}" )
fi

if chk_enabled "${STREAM1090_ENABLE_IQ_FILTER:-false}"; then
    stream_cmd+=( -q )
fi

if [[ -n "${STREAM1090_TAPS_FILE:-}" ]]; then
    stream_cmd+=( -f "${STREAM1090_TAPS_FILE}" )
fi

if chk_enabled "${STREAM1090_VERBOSE:-false}"; then
    stream_cmd+=( -v )
fi

"${s6wrap[@]}" echo "Starting stream1090 and exposing RAW output on ${host}:${port}"

tmp_pipe="$(mktemp -u /tmp/stream1090.XXXXXX.pipe)"
mkfifo "$tmp_pipe"

cleanup() {
    rm -f "$tmp_pipe"
}

terminate_children() {
    local pids=()
    [[ -n "${stream_pid:-}" ]] && pids+=("$stream_pid")
    [[ -n "${socat_pid:-}" ]] && pids+=("$socat_pid")
    if [[ "${#pids[@]}" -gt 0 ]]; then
        kill "${pids[@]}" 2>/dev/null || true
    fi
}

on_term() {
    terminate_children
    [[ -n "${stream_pid:-}" ]] && wait "$stream_pid" 2>/dev/null || true
    [[ -n "${socat_pid:-}" ]] && wait "$socat_pid" 2>/dev/null || true
    exit 143
}

trap on_term INT TERM
trap cleanup EXIT

socat -u "$tmp_pipe" "TCP-LISTEN:${port},bind=${host},reuseaddr,fork" &
socat_pid=$!

"${stream_cmd[@]}" > "$tmp_pipe" &
stream_pid=$!

# Fail fast: as soon as either side exits, terminate the other side and stop.
if wait -n "$stream_pid" "$socat_pid"; then
    exit_code=0
else
    exit_code=$?
fi

terminate_children
wait "$stream_pid" 2>/dev/null || true
wait "$socat_pid" 2>/dev/null || true

if [[ "$exit_code" -eq 0 ]]; then
    exit 1
fi

exit "$exit_code"
